# Normal development and production use the real Fedimint adapter.
VITE_WALLET_MODE=fedimint

# To opt into the development-only simulation, use `npm run dev:fake` instead.
# Production builds reject fake mode. Federation guardian endpoints are
# discovered from the invite code and limited to secure HTTPS/WSS schemes.

# Development-only disposable real-SDK wallet. Use `npm run dev:test-wallet`;
# the flag is ignored by production builds.
# VITE_TEST_WALLET_BYPASS=true

# Experimental real MDK chat. Keep disabled unless explicitly testing the
# browser runtime; there is no fake fallback when `mdk` is selected.
# VITE_CHAT_MODE=mdk
# VITE_MARMOT_RELAYS=wss://your-relay.example
# Build the combined wallet + real chat PWA with:
# VITE_MARMOT_RELAYS=wss://your-relay.example npm run build:production-chat
# Development-only opt-in for a deterministic ws://localhost relay:
# VITE_MARMOT_ALLOW_INSECURE_LOCALHOST=true
